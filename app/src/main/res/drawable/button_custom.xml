<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#b890c4"/>
            <stroke android:color="#5b337d"
                android:width="3dp"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#f5d85f"/>
            <stroke android:color="#5b337d"
                android:width="3dp"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>